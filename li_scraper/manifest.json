{
  "manifest_version": 3,
  "name": "LinkedIn Job Scraper",
  "version": "1.0",
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs-tracker/*"
      ],
      "js": ["phase1.js"]
    },
    {
      "matches": ["https://www.linkedin.com/jobs/view/*"],
      "js": ["phase2.js"]
    }
  ]
}
